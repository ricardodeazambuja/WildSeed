# Generated outputs
models/
worlds/*
# ...except hand-authored spike/test worlds (source, not generated).
# NOTE: the pattern above must stay `worlds/*` (not `worlds/`) or git will not
# descend into the dir and the negation below can never match.
!worlds/sensor_spike.world
Blender-Assets/*.blend
Blender-Assets/**/*.blend

# Spike raw render data (regenerable)
frames/

# Flight recordings (videos/datasets; reproducible from seed + world)
runs/

# Synthesized DEMs (reproducible from seed+preset; bundled DEMs stay tracked)
dem/synth*
dem/*.lakes.json

# Raw asset downloads + staging (registry is the durable record)
Blender-Assets/**/_raw*/
Blender-Assets/.hero/
Blender-Assets/**/textures/
Blender-Assets/soil/_raw_*/

# Asset build staging (transient; regenerated by tools/build_assets.py)
Blender-Assets/_stage/
dem/scenario_*.tif
dem/scenario_*.lakes.json
worlds/scenario_*

# Upstream Forest3D reference screenshots (renders of commercial assets; local-only
# baselines for tools/compare.py — not redistributed)
Screenshot from 2026-*.png

# Session scratch/working files (not part of the repo)
scratchpad/
